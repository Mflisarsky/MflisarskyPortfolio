---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort((a, b) =>
  a.localeCompare(b, undefined, { sensitivity: 'base' }),
);
---

<BaseLayout title="Projects | Cybersecurity Portfolio" description="Security projects: homelab, SIEM detection rules, network scanning, and defensive security work.">
  <div class="container">
    <h1>Projects</h1>
    <p class="page-intro">Homelab, detection engineering, and defensive security projects.</p>

    <div class="filters">
      <div class="search-wrap">
        <label for="search" class="sr-only">Search projects</label>
        <input
          type="search"
          id="search"
          class="search-input"
          placeholder="Search by title or summary..."
          aria-label="Search projects"
        />
      </div>
      <div class="tag-filters" id="tag-filters">
        <button type="button" class="btn tag-filter active" data-tag="">All</button>
        {allTags.map((tag) => (
          <button type="button" class="btn tag-filter" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div class="project-list" id="project-list">
      {allProjects.map((entry) => (
        <article
          class="card project-card"
          data-title={entry.data.title.toLowerCase()}
          data-summary={entry.data.summary.toLowerCase()}
          data-tags={JSON.stringify(entry.data.tags.map((t) => t.toLowerCase()))}
        >
          <h2><a href={`/projects/${entry.id}`}>{entry.data.title}</a></h2>
          <p class="project-summary">{entry.data.summary}</p>
          <div class="project-meta">
            <time datetime={entry.data.date.toISOString()}>
              {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}
            </time>
            <div class="tags">
              {entry.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
          <a href={`/projects/${entry.id}`} class="btn btn-primary">View project</a>
        </article>
      ))}
    </div>

    <p class="no-results hidden" id="no-results">No projects match your filters.</p>
  </div>

  <script>
    function initProjectFilters() {
      const searchInput = /** @type {HTMLInputElement | null} */ (document.getElementById('search'));
      const tagFilters = document.getElementById('tag-filters');
      const projectList = document.getElementById('project-list');
      const noResults = document.getElementById('no-results');
      if (!searchInput || !tagFilters || !projectList || !noResults) return;

      const cards = Array.from(projectList.querySelectorAll('.project-card'));

      function filterProjects() {
        const query = (searchInput.value || '').toLowerCase().trim();
        const activeTag =
          (tagFilters.querySelector('.tag-filter.active')?.getAttribute('data-tag') || '').toLowerCase();

        let visible = 0;
        for (const card of cards) {
          const title = (card.getAttribute('data-title') || '').toLowerCase();
          const summary = (card.getAttribute('data-summary') || '').toLowerCase();
          const tagsRaw = card.getAttribute('data-tags') || '[]';
          let tags = [];
          try {
            tags = JSON.parse(tagsRaw);
          } catch {
            tags = [];
          }

          const matchSearch = !query || title.includes(query) || summary.includes(query);
          const matchTag = !activeTag || tags.includes(activeTag);
          const show = matchSearch && matchTag;

          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }

        noResults.classList.toggle('hidden', visible > 0);
      }

      searchInput.addEventListener('input', filterProjects);
      tagFilters.addEventListener('click', (e) => {
        const btn = /** @type {HTMLElement | null} */ (e.target)?.closest?.('.tag-filter');
        if (!btn) return;
        tagFilters.querySelectorAll('.tag-filter').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        filterProjects();
      });

      // Initial state
      filterProjects();
    }

    // Astro view transitions re-render pages; re-init on each page load.
    document.addEventListener('astro:page-load', initProjectFilters);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProjectFilters, { once: true });
    } else {
      initProjectFilters();
    }
  </script>
</BaseLayout>

<style>
  .page-intro {
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .filters {
    margin-bottom: 2rem;
  }
  .search-wrap {
    margin-bottom: 1rem;
  }
  .search-input {
    width: 100%;
    max-width: 400px;
    padding: 0.6rem 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: 1rem;
  }
  .search-input::placeholder {
    color: var(--text-muted);
  }
  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-filter.active {
    border-color: var(--accent);
    color: var(--accent);
  }
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .project-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .project-card h2 a {
    color: inherit;
  }
  .project-card h2 a:hover {
    color: var(--accent);
  }
  .project-summary {
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
  .project-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .hidden {
    display: none !important;
  }
</style>
